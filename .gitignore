# XcodeGen 生成物(从不手改、从不打开)
BusyElf.xcodeproj/

# XcodeGen 由 project.yml 生成的 Info.plist / entitlements(单一真相源是 project.yml)
BusyElf-Info.plist
BusyElf.entitlements

# 构建产物
build/
DerivedData/
*.xcarchive
*.zip

# 代码覆盖率原始 profile(xcodebuild test 插桩生成)
*.profraw
*.profdata

# macOS
.DS_Store

# 调试期抓 hook payload 用
busyelf-hook-capture.ndjson

# Claude Code 本地设置(含 BusyElf 适配器钩子;个人本地,不入库)
.claude/settings.local.json
